    {
      "parameters": {
        "jsCode": "// ============================================================================\n// NODO: Procesar respuesta\n// Versión: 3.0.0 - Solo auto-confirmación por tiempo (sin HTTP)\n// Fecha: 22 Marzo 2026\n// Razón: Remax devuelve HTTP 200 genérico para props removidas (SPA),\n//        igual que C21. HTTP no sirve como señal. Discovery es la fuente\n//        de verdad. Si la prop reaparece, Discovery la reactiva.\n// ============================================================================\n\nconst item = $input.first();\nconst propiedadData = $('Split propiedades').first().json;\nconst diasDesdeAusencia = propiedadData.dias_desde_ausencia || 0;\nconst primeraAusenciaAt = propiedadData.primera_ausencia_at;\n\nconst MAX_DIAS_PENDING = 2; // Días antes de auto-confirmar\n\nlet action = 'skip';\nlet newStatus = null;\nlet reason = '';\n\nif (!primeraAusenciaAt) {\n  action = 'skip';\n  reason = 'ERROR: primera_ausencia_at es NULL';\n} else if (diasDesdeAusencia >= MAX_DIAS_PENDING) {\n  action = 'confirm';\n  newStatus = 'inactivo_confirmed';\n  reason = `Auto-confirmado: ${diasDesdeAusencia} días ausente (límite: ${MAX_DIAS_PENDING})`;\n} else {\n  action = 'skip';\n  reason = `Esperando: día ${diasDesdeAusencia}/${MAX_DIAS_PENDING}`;\n}\n\nreturn [{\n  json: {\n    id: propiedadData.id,\n    url: propiedadData.url,\n    fuente: propiedadData.fuente,\n    codigo_propiedad: propiedadData.codigo_propiedad,\n    primera_ausencia_at: primeraAusenciaAt,\n    action: action,\n    newStatus: newStatus,\n    reason: reason,\n    diasDesdeAusencia: diasDesdeAusencia,\n    maxDiasPending: MAX_DIAS_PENDING,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "90833967-e280-417e-b1b9-69095a828b31",
